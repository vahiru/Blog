---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "astro-mochi-tones:layouts/Layout.astro";
import Waline from "astro-mochi-tones:components/Waline.astro";
import themeConfig from "astro-mochi-tones:config";
import "@material/web/icon/icon.js";
import "@material/web/divider/divider.js";

interface Props {
  post: CollectionEntry<"blog">;
  prevPost: CollectionEntry<"blog"> | null;
  nextPost: CollectionEntry<"blog"> | null;
}

const getPostSlug = (entry: CollectionEntry<"blog">) =>
  "slug" in entry && typeof entry.slug === "string"
    ? entry.slug
    : entry.id.replace(/\.(md|mdx)$/i, "");

export async function getStaticPaths() {
  const getSlug = (entry: CollectionEntry<"blog">) =>
    "slug" in entry && typeof entry.slug === "string"
      ? entry.slug
      : entry.id.replace(/\.(md|mdx)$/i, "");
  const allPosts = await getCollection("blog");
  const sortedPosts = allPosts
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sortedPosts.map((post, index) => ({
    params: { slug: getSlug(post) },
    props: {
      post,
      nextPost: index > 0 ? sortedPosts[index - 1] : null,
      prevPost: index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
const { labels } = themeConfig;

const fallbackTitle = (entry: CollectionEntry<"blog"> | null) =>
  entry?.data.title ||
  (entry ? getPostSlug(entry) : "").split("/").pop()?.replace(/-/g, " ") ||
  labels.untitled;

const postTitle = fallbackTitle(post);
const postCover = post.data.cover;
const postTags = post.data.tags ?? [];
const postCategories = post.data.categories ?? [];
const formattedDate = post.data.date.toLocaleDateString(themeConfig.lang, {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const bannerRoles = [
  {
    background: "var(--md-sys-color-primary-container)",
    foreground: "var(--md-sys-color-on-primary-container)",
  },
  {
    background: "var(--md-sys-color-secondary-container)",
    foreground: "var(--md-sys-color-on-secondary-container)",
  },
  {
    background: "var(--md-sys-color-tertiary-container)",
    foreground: "var(--md-sys-color-on-tertiary-container)",
  },
] as const;
const bannerRole = bannerRoles[postTitle.length % bannerRoles.length] ?? bannerRoles[0];
const bannerStyle = `--article-banner: ${bannerRole.background}; --article-on-banner: ${bannerRole.foreground}`;
const description = post.data.description ?? post.body?.slice(0, 160) ?? postTitle;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<Layout
  title={postTitle}
  description={description}
  image={postCover}
  articleDate={post.data.date}
>
  <div class="blog-layout">
    <main class="article-wrapper">
      <article class="post-card">
        <header class="post-header">
          <a class="back-link" href="/">
            <md-icon aria-hidden="true">arrow_back</md-icon>
            <span>{labels.backHome}</span>
          </a>

          {
            postCover ? (
              <div class="cover-wrapper" style={bannerStyle}>
                <div class="cover-fallback" aria-hidden="true">
                  <md-icon>article</md-icon>
                </div>
                <img
                  src={postCover}
                  alt={`《${postTitle}》封面`}
                  class="post-cover"
                  data-post-cover
                  decoding="async"
                  fetchpriority="high"
                  referrerpolicy="no-referrer"
                />
              </div>
            ) : (
              <div class="title-banner" style={bannerStyle} aria-hidden="true">
                <md-icon>article</md-icon>
                <span>ARTICLE</span>
              </div>
            )
          }

          <div class="header-text">
            <p class="article-eyebrow">ARTICLE</p>
            <h1>{postTitle}</h1>
            <div class="post-meta">
              <span class="meta-item">
                <md-icon aria-hidden="true">calendar_today</md-icon>
                <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
              </span>
              {
                postCategories.map((category) => (
                  <a class="meta-item meta-link" href={`/categories/${encodeURIComponent(category)}`}>
                    <md-icon aria-hidden="true">folder</md-icon>
                    <span>{category}</span>
                  </a>
                ))
              }
            </div>
          </div>
        </header>

        <md-divider></md-divider>

        <div class="post-content typo">
          <Content />
        </div>

        <md-divider></md-divider>

        {
          postTags.length > 0 && (
            <footer class="post-footer" aria-label="文章标签">
              <md-icon aria-hidden="true">label</md-icon>
              <div class="tags-list">
                {postTags.map((tag) => (
                  <a href={`/tags/${encodeURIComponent(tag)}`} class="tag-chip">
                    #{tag}
                  </a>
                ))}
              </div>
            </footer>
          )
        }

        <Waline />
      </article>

      {
        (prevPost || nextPost) && (
          <nav class="post-nav" aria-label="相邻文章">
            {prevPost && (
              <a href={`/blog/${getPostSlug(prevPost)}`} class="nav-link prev">
                <span class="nav-label">
                  <md-icon aria-hidden="true">arrow_back</md-icon>
                  {labels.previousPost}
                </span>
                <span class="nav-title">{fallbackTitle(prevPost)}</span>
              </a>
            )}

            {nextPost && (
              <a href={`/blog/${getPostSlug(nextPost)}`} class="nav-link next">
                <span class="nav-label">
                  {labels.nextPost}
                  <md-icon aria-hidden="true">arrow_forward</md-icon>
                </span>
                <span class="nav-title">{fallbackTitle(nextPost)}</span>
              </a>
            )}
          </nav>
        )
      }
    </main>

    <aside class="toc-sidebar" aria-label={labels.tocTitle}>
      <nav class="toc-sticky">
        <div class="toc-header">
          <md-icon aria-hidden="true">format_list_bulleted</md-icon>
          <span>{labels.tocTitle}</span>
        </div>
        {
          tocHeadings.length > 0 ? (
            <ul>
              {tocHeadings.map((heading) => (
                <li class={`depth-${heading.depth}`}>
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))}
            </ul>
          ) : (
            <p>{labels.noHeadings}</p>
          )
        }
      </nav>
    </aside>
  </div>
</Layout>

<script>
  const createMaterialIcon = (name: string) => {
    const icon = document.createElement("span");
    icon.className = "material-symbols-rounded";
    icon.setAttribute("aria-hidden", "true");
    icon.textContent = name;
    return icon;
  };

  const setCopyButtonState = (button: HTMLButtonElement, icon: string, label: string) => {
    button.replaceChildren(createMaterialIcon(icon));
    button.setAttribute("aria-label", label);
    button.title = label;
  };

  const copyText = async (value: string) => {
    if (!navigator.clipboard?.writeText) throw new Error("Clipboard API is unavailable");
    await navigator.clipboard.writeText(value);
  };

  document.querySelectorAll<HTMLImageElement>("[data-post-cover]").forEach((image) => {
    const showFallback = () => {
      image.hidden = true;
    };
    image.addEventListener("error", showFallback, { once: true });
    if (image.complete && image.naturalWidth === 0) showFallback();
  });

  document.querySelectorAll<HTMLPreElement>(".post-content pre").forEach((pre) => {
    if (pre.parentElement?.classList.contains("code-wrapper")) return;
    const parent = pre.parentNode;
    if (!parent) return;

    const wrapper = document.createElement("div");
    wrapper.className = "code-wrapper";
    const header = document.createElement("div");
    header.className = "code-header";

    const language = pre.dataset.language || pre.querySelector("code")?.className.match(/language-([\w-]+)/)?.[1] || "code";
    const languageLabel = document.createElement("span");
    languageLabel.className = "code-lang";
    languageLabel.textContent = language.toUpperCase();

    const button = document.createElement("button");
    button.type = "button";
    button.className = "copy-btn";
    button.setAttribute("aria-live", "polite");
    setCopyButtonState(button, "content_copy", "复制代码");
    button.addEventListener("click", async () => {
      button.disabled = true;
      try {
        await copyText(pre.innerText);
        setCopyButtonState(button, "check", "已复制");
      } catch (error) {
        console.error("Failed to copy code", error);
        setCopyButtonState(button, "error", "复制失败");
      } finally {
        window.setTimeout(() => {
          setCopyButtonState(button, "content_copy", "复制代码");
          button.disabled = false;
        }, 1800);
      }
    });

    header.append(languageLabel, button);
    parent.insertBefore(wrapper, pre);
    wrapper.append(header, pre);
  });
</script>

<style is:global>
  .astro-code,
  .astro-code span {
    color: var(--shiki-light) !important;
  }

  :root.dark .astro-code,
  :root.dark .astro-code span {
    color: var(--shiki-dark) !important;
  }

  .astro-code span {
    background-color: transparent !important;
  }

  .code-wrapper {
    overflow: hidden;
    margin: 28px 0;
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: var(--md-sys-shape-corner-large-increased);
    background: var(--md-sys-color-surface-container);
  }

  .code-header {
    display: flex;
    min-height: 48px;
    align-items: center;
    justify-content: space-between;
    padding: 6px 8px 6px 18px;
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
    background: var(--md-sys-color-surface-container-high);
  }

  .code-lang {
    color: var(--md-sys-color-on-surface-variant);
    font-size: var(--md-sys-typescale-label-medium-size);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .copy-btn {
    display: grid;
    width: 40px;
    height: 40px;
    place-items: center;
    border-radius: var(--md-sys-shape-corner-full);
    background: transparent;
    color: var(--md-sys-color-on-surface-variant);
    cursor: pointer;
    transition: background-color var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects);
  }

  .copy-btn:hover {
    background: color-mix(in srgb, var(--md-sys-color-on-surface) 8%, transparent);
  }

  .copy-btn:disabled {
    cursor: wait;
    opacity: 0.72;
  }

  .copy-btn .material-symbols-rounded {
    font-size: 20px;
  }

  .astro-code {
    margin: 0;
    overflow-x: auto;
    padding: 22px;
    background: var(--md-sys-color-surface-container) !important;
    font-family: "Cascadia Code", "Fira Code", Consolas, "Noto Sans SC", monospace;
    font-size: 0.875rem;
    line-height: 1.65;
  }

  .astro-code code {
    counter-reset: code-line;
  }

  .astro-code .line {
    display: inline-block;
    min-width: 100%;
  }

  .astro-code .line::before {
    display: inline-block;
    width: 2.5rem;
    margin-right: 1rem;
    padding-right: 0.75rem;
    border-right: 1px solid var(--md-sys-color-outline-variant);
    color: var(--md-sys-color-on-surface-variant);
    content: counter(code-line);
    counter-increment: code-line;
    opacity: 0.56;
    text-align: right;
    user-select: none;
  }

  .typo {
    color: var(--md-sys-color-on-surface);
    font-size: var(--md-sys-typescale-body-large-size);
    line-height: 1.82;
  }

  .typo h2,
  .typo h3,
  .typo h4 {
    color: var(--md-sys-color-on-surface);
    font-family: var(--md-ref-typeface-brand);
    scroll-margin-top: 88px;
  }

  .typo h2 {
    margin: 52px 0 18px;
    font-size: var(--md-sys-typescale-headline-medium-size);
    line-height: var(--md-sys-typescale-headline-medium-line-height);
    font-weight: 500;
  }

  .typo h3 {
    margin: 36px 0 14px;
    font-size: var(--md-sys-typescale-headline-small-size);
    line-height: var(--md-sys-typescale-headline-small-line-height);
    font-weight: 500;
  }

  .typo h4 {
    margin: 28px 0 12px;
    font-size: var(--md-sys-typescale-title-large-size);
    line-height: var(--md-sys-typescale-title-large-line-height);
  }

  .typo p,
  .typo ul,
  .typo ol {
    margin-block: 0 24px;
  }

  .typo ul,
  .typo ol {
    padding-left: 1.6em;
  }

  .typo li + li {
    margin-top: 8px;
  }

  .typo a {
    color: var(--md-sys-color-primary);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 40%, transparent);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .typo a:hover {
    text-decoration-color: currentColor;
  }

  .typo blockquote {
    margin: 28px 0;
    padding: 18px 22px;
    border-left: 4px solid var(--md-sys-color-primary);
    border-radius: 0 var(--md-sys-shape-corner-large) var(--md-sys-shape-corner-large) 0;
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
  }

  .typo blockquote > :last-child {
    margin-bottom: 0;
  }

  .typo code:not(pre code) {
    padding: 2px 7px;
    border-radius: var(--md-sys-shape-corner-small);
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
    font-family: "Cascadia Code", Consolas, monospace;
    font-size: 0.88em;
  }

  .typo img {
    display: block;
    height: auto;
    margin: 32px auto;
    border-radius: var(--md-sys-shape-corner-large-increased);
  }

  .typo table {
    display: block;
    width: 100%;
    margin: 28px 0;
    overflow-x: auto;
    border-collapse: collapse;
  }

  .typo th,
  .typo td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--md-sys-color-outline-variant);
    text-align: left;
  }

  .typo th {
    background: var(--md-sys-color-surface-container-high);
    font-weight: 600;
  }

  .typo hr {
    margin: 40px 0;
    border: 0;
    border-top: 1px solid var(--md-sys-color-outline-variant);
  }

  @media (max-width: 599px) {
    .astro-code {
      padding: 18px;
      font-size: 0.8125rem;
    }

    .astro-code .line::before {
      display: none;
    }

    .typo {
      line-height: 1.76;
    }

    .typo h2 {
      margin-top: 42px;
      font-size: var(--md-sys-typescale-headline-small-size);
      line-height: var(--md-sys-typescale-headline-small-line-height);
    }
  }
</style>

<style>
  .blog-layout {
    display: grid;
    width: min(100%, 1280px);
    gap: 32px;
    margin-inline: auto;
    align-items: start;
  }

  .article-wrapper {
    min-width: 0;
  }

  .post-card {
    padding: clamp(24px, 5vw, 56px);
    border-radius: var(--md-sys-shape-corner-extra-large-increased);
    background: var(--md-sys-color-surface-container-lowest);
    box-shadow: var(--md-sys-elevation-level1);
  }

  .post-header {
    margin-bottom: 32px;
  }

  .back-link {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    gap: 8px;
    margin: -8px 0 24px -10px;
    padding: 8px 14px 8px 10px;
    border-radius: var(--md-sys-shape-corner-full);
    color: var(--md-sys-color-primary);
    font-size: var(--md-sys-typescale-label-large-size);
    font-weight: var(--md-sys-typescale-label-large-weight);
    transition: background-color var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects);
  }

  .back-link:hover {
    background: color-mix(in srgb, var(--md-sys-color-primary) 8%, transparent);
  }

  .cover-wrapper,
  .title-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: clamp(28px, 5vw, 48px);
    border-radius: var(--md-sys-shape-corner-extra-large);
    background: var(--article-banner);
    color: var(--article-on-banner);
  }

  .cover-wrapper {
    aspect-ratio: 16 / 8.5;
    max-height: 480px;
  }

  .cover-fallback,
  .title-banner {
    display: grid;
    place-items: center;
  }

  .cover-fallback {
    position: absolute;
    inset: 0;
  }

  .cover-fallback md-icon,
  .title-banner md-icon {
    width: 64px;
    height: 64px;
    font-size: 64px;
    opacity: 0.5;
  }

  .post-cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-cover[hidden] {
    display: none;
  }

  .title-banner {
    min-height: 220px;
    align-content: center;
    gap: 14px;
  }

  .title-banner span {
    font-size: var(--md-sys-typescale-label-medium-size);
    font-weight: 700;
    letter-spacing: 0.18em;
    opacity: 0.7;
  }

  .header-text {
    max-width: 820px;
  }

  .article-eyebrow {
    margin: 0 0 8px;
    color: var(--md-sys-color-primary);
    font-size: var(--md-sys-typescale-label-medium-size);
    font-weight: 700;
    letter-spacing: 0.16em;
  }

  h1 {
    margin: 0;
    color: var(--md-sys-color-on-surface);
    font-family: var(--md-ref-typeface-brand);
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.13;
    font-weight: 500;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    margin-top: 20px;
    color: var(--md-sys-color-on-surface-variant);
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: var(--md-sys-typescale-body-medium-size);
  }

  .meta-item md-icon {
    width: 19px;
    height: 19px;
    font-size: 19px;
  }

  .meta-link {
    border-radius: var(--md-sys-shape-corner-small);
    color: var(--md-sys-color-primary);
  }

  .post-content {
    padding: clamp(28px, 5vw, 52px) 0;
  }

  .post-footer {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding-top: 28px;
  }

  .post-footer > md-icon {
    margin-top: 8px;
    color: var(--md-sys-color-on-surface-variant);
    font-size: 20px;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-chip {
    min-height: 36px;
    padding: 7px 14px;
    border-radius: var(--md-sys-shape-corner-small);
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
    font-size: var(--md-sys-typescale-label-large-size);
    font-weight: var(--md-sys-typescale-label-large-weight);
    transition:
      border-radius var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-spatial),
      background-color var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects);
  }

  .tag-chip:hover {
    border-radius: var(--md-sys-shape-corner-full);
    background: color-mix(in srgb, var(--md-sys-color-on-secondary-container) 16%, var(--md-sys-color-secondary-container));
  }

  .post-nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 14px;
    margin-top: 24px;
  }

  .nav-link {
    display: flex;
    min-width: 0;
    min-height: 112px;
    flex-direction: column;
    justify-content: center;
    padding: 22px 24px;
    border-radius: var(--md-sys-shape-corner-extra-large);
    background: var(--md-sys-color-surface-container-low);
    transition:
      translate var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-spatial),
      background-color var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects);
  }

  .nav-link:hover {
    translate: 0 -2px;
    background: var(--md-sys-color-surface-container-high);
  }

  .nav-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
    color: var(--md-sys-color-primary);
    font-size: var(--md-sys-typescale-label-medium-size);
    font-weight: 600;
  }

  .nav-label md-icon {
    font-size: 20px;
  }

  .nav-title {
    display: -webkit-box;
    overflow: hidden;
    color: var(--md-sys-color-on-surface);
    font-size: var(--md-sys-typescale-title-medium-size);
    line-height: var(--md-sys-typescale-title-medium-line-height);
    font-weight: 600;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .nav-link.next {
    align-items: flex-end;
    text-align: right;
  }

  .toc-sidebar {
    display: none;
  }

  .toc-sticky {
    position: sticky;
    top: 24px;
    padding: 22px;
    border-radius: var(--md-sys-shape-corner-large-increased);
    background: var(--md-sys-color-surface-container-low);
  }

  .toc-header {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-bottom: 14px;
    color: var(--md-sys-color-on-surface);
    font-size: var(--md-sys-typescale-title-small-size);
    font-weight: 600;
  }

  .toc-header md-icon {
    color: var(--md-sys-color-primary);
    font-size: 20px;
  }

  .toc-sticky ul {
    display: grid;
    gap: 2px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .toc-sticky a {
    display: block;
    padding: 7px 10px;
    border-radius: var(--md-sys-shape-corner-small);
    color: var(--md-sys-color-on-surface-variant);
    font-size: var(--md-sys-typescale-body-small-size);
    line-height: var(--md-sys-typescale-body-small-line-height);
    transition:
      background-color var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects),
      color var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects);
  }

