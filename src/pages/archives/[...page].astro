---
import type { GetStaticPaths, Page } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";
import ArchiveView from "astro-mochi-tones:components/ArchiveView.astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((left, right) => right.data.date.valueOf() - left.data.date.valueOf());
  return paginate(posts, { pageSize: 6 });
};

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
const allPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((left, right) => right.data.date.valueOf() - left.data.date.valueOf());
const categoryCounts = new Map<string, number>();

for (const post of allPosts) {
  for (const category of post.data.categories ?? []) {
    categoryCounts.set(category, (categoryCounts.get(category) ?? 0) + 1);
  }
}

const categories = [...categoryCounts.entries()].sort(
  ([leftName, leftCount], [rightName, rightCount]) =>
    rightCount - leftCount || leftName.localeCompare(rightName),
);
const totalYears = new Set(
  allPosts.map((post) => {
    const date = post.data.date instanceof Date ? post.data.date : new Date(post.data.date);
    return Number.isNaN(date.valueOf()) ? "invalid" : String(date.getFullYear());
  }),
).size;
---

<ArchiveView page={page} categories={categories} totalPosts={allPosts.length} totalYears={totalYears} />
