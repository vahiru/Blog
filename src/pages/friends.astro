---
import Layout from "astro-mochi-tones:layouts/Layout.astro";
import { friendsData } from "../data/friends";
import "@material/web/icon/icon.js";
---

<Layout title="友情链接">
  <div class="md3-layout-grid">
    <div class="content-wrapper">
      <!-- 页面头部 -->
      <header class="page-header">
        <h1 class="display-large">友情链接</h1>
        <p class="body-large secondary-text">
          很高兴认识你。欢迎交换友链，请在 GitHub 提交 Issue 或联系我。
        </p>
      </header>

      <div class="friends-main-layout">
        <main class="friends-content">
          <h2 class="title-large section-label">我的朋友们</h2>
          <div class="friends-grid">
            {
              friendsData.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="friend-card"
                >
                  <div class="avatar-box">
                    {link.avatar ? (
                      <img src={link.avatar} alt={link.name} loading="lazy" />
                    ) : (
                      <md-icon class="fallback-icon">public</md-icon>
                    )}
                  </div>

                  <div class="info-box">
                    <div class="name-row">
                      <h3 class="friend-name title-medium">{link.name}</h3>
                      <md-icon class="arrow-icon">open_in_new</md-icon>
                    </div>
                    <p class="friend-desc body-small">{link.desc}</p>
                  </div>
                  <md-ripple></md-ripple>
                </a>
              ))
            }
          </div>
        </main>

        <aside class="sidebar">
          <section class="sidebar-section">
            <h3 class="label-large">申请说明</h3>
            <p class="body-medium sidebar-text">
              如果你也想加入这个列表，请确保你的网站：
            </p>
            <ul class="body-small sidebar-list">
              <li>内容健康、积极向上</li>
              <li>已添加本站链接</li>
              <li>非纯采集或广告站点</li>
            </ul>
            <div class="sidebar-actions">
              <md-filled-tonal-button href="https://github.com/vahiru/blog/issues" target="_blank">
                提交申请
                <md-icon slot="icon">add</md-icon>
              </md-filled-tonal-button>
            </div>
          </section>
        </aside>
      </div>
    </div>
  </div>
</Layout>

<script>
  import "@material/web/ripple/ripple.js";
  import "@material/web/button/filled-tonal-button.js";
</script>

<style>
  /* === 布局网格 === */
  .md3-layout-grid {
    display: flex;
    flex-direction: column;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .content-wrapper {
    width: 100%;
    box-sizing: border-box;
  }

  .page-header {
    padding: 4rem 1rem 3rem 1rem;
    max-width: 800px;
  }

  .page-header h1 {
    margin-bottom: 1rem;
    color: var(--md-sys-color-on-surface);
  }

  .secondary-text {
    color: var(--md-sys-color-on-surface-variant);
  }

  .friends-main-layout {
    display: grid;
    gap: 24px;
    padding: 0 1rem;
  }

  /* 桌面端布局 */
  @media (min-width: 840px) {
    .friends-main-layout {
      grid-template-columns: repeat(12, 1fr);
      padding-top: 1rem;
    }
    .friends-content {
      grid-column: span 8;
    }
    .sidebar {
      grid-column: span 4;
      position: sticky;
      top: 2rem;
      height: fit-content;
    }
  }

  /* 平板端布局 */
  @media (min-width: 600px) and (max-width: 839px) {
    .friends-main-layout {
      grid-template-columns: repeat(8, 1fr);
    }
    .friends-content, .sidebar {
      grid-column: span 8;
    }
    .sidebar {
      margin-top: 2rem;
    }
  }

  /* 移动端布局 */
  @media (max-width: 599px) {
    .friends-main-layout {
      display: block;
      padding: 0;
    }
    .page-header {
      padding: 2rem 0;
    }
    .page-header h1 {
      font-size: 2.5rem;
    }
    .sidebar-section {
      background: transparent !important;
      border-bottom: 1px solid var(--md-sys-color-outline-variant);
      border-radius: 0 !important;
      padding: 1rem 0 !important;
    }
  }

  .section-label {
    margin-bottom: 1.5rem;
    color: var(--md-sys-color-on-surface);
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* === 友情链接网格 === */
  .friends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  /* === 友链卡片 (MD3 Elevated Card Style) === */
  .friend-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px;
    background-color: var(--md-sys-color-surface-container-low);
    border-radius: 20px;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1), background-color 0.2s;
    box-shadow: var(--md-sys-elevation-level1);
  }

  .friend-card:hover {
    transform: translateY(-4px);
    background-color: var(--md-sys-color-surface-container-high);
    box-shadow: var(--md-sys-elevation-level2);
  }

  .avatar-box {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: 16px; /* Squircle style */
    background-color: var(--md-sys-color-surface-variant);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--md-sys-color-outline-variant);
  }

  .avatar-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fallback-icon {
    color: var(--md-sys-color-on-surface-variant);
    opacity: 0.5;
  }

  .info-box {
    flex: 1;
    min-width: 0;
  }

  .name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2px;
  }

  .friend-name {
    margin: 0;
    color: var(--md-sys-color-on-surface);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .friend-desc {
    margin: 0;
    color: var(--md-sys-color-on-surface-variant);
    opacity: 0.8;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .arrow-icon {
    font-size: 18px;
    color: var(--md-sys-color-primary);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    transform: translateX(-4px);
  }

  .friend-card:hover .arrow-icon {
    opacity: 1;
    transform: translateX(0);
  }

  /* === 侧边栏小部件 === */
  .sidebar-section {
    background-color: var(--md-sys-color-surface-container);
    padding: 1.5rem;
    border-radius: 24px;
    box-shadow: var(--md-sys-elevation-level1);
  }

  .sidebar-section h3 {
    margin-bottom: 1rem;
    color: var(--md-sys-color-primary);
    font-weight: 600;
  }

  .sidebar-text {
    color: var(--md-sys-color-on-surface);
    margin-bottom: 1rem;
  }

  .sidebar-list {
    margin: 0 0 1.5rem 0;
    padding-left: 1.25rem;
    color: var(--md-sys-color-on-surface-variant);
  }

  .sidebar-list li {
    margin-bottom: 4px;
  }
</style>
