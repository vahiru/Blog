---
import Layout from "astro-mochi-tones:layouts/Layout.astro";
import { friendsData } from "../data/friends";
import "@material/web/icon/icon.js";

const isHttpsUrl = (value: string) => {
  try {
    return new URL(value).protocol === "https:";
  } catch {
    return false;
  }
};

const friends = friendsData.filter(
  (friend) => isHttpsUrl(friend.url) && isHttpsUrl(friend.avatar),
);
---

<Layout title="友情链接">
  <div class="friends-page">
    <header class="page-intro">
      <div class="intro-icon" aria-hidden="true"><md-icon>diversity_3</md-icon></div>
      <div>
        <p class="eyebrow">FRIENDS AROUND THE WEB</p>
        <h1>友情链接</h1>
        <p class="intro-copy">很高兴认识你。这里收藏着一些值得拜访的网络邻居，也欢迎你来交换友链。</p>
      </div>
    </header>

    <div class="friends-layout">
      <main class="friends-content" aria-labelledby="friends-heading">
        <div class="section-heading">
          <h2 id="friends-heading">我的朋友们</h2>
          <span class="count-badge">{friends.length} 位</span>
        </div>

        <div class="friends-grid">
          {
            friends.map((friend) => (
              <a
                href={friend.url}
                target="_blank"
                rel="noopener noreferrer"
                class="friend-card"
                aria-label={`访问 ${friend.name}（新窗口打开）`}
              >
                <div class="avatar-box">
                  <md-icon class="fallback-icon" aria-hidden="true">public</md-icon>
                  <img
                    src={friend.avatar}
                    alt=""
                    class="friend-avatar"
                    width="64"
                    height="64"
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                  />
                </div>

                <div class="friend-info">
                  <div class="name-row">
                    <h3>{friend.name}</h3>
                    <md-icon class="arrow-icon" aria-hidden="true">north_east</md-icon>
                  </div>
                  <p>{friend.desc}</p>
                </div>
                <md-ripple></md-ripple>
              </a>
            ))
          }
        </div>
      </main>

      <aside class="application-card" aria-labelledby="application-heading">
        <div class="application-icon" aria-hidden="true"><md-icon>person_add</md-icon></div>
        <h2 id="application-heading">成为新邻居</h2>
        <p>如果你也想加入这个列表，请先确认你的网站符合以下条件：</p>
        <ul>
          <li><md-icon aria-hidden="true">check_circle</md-icon><span>内容健康、积极向上</span></li>
          <li><md-icon aria-hidden="true">check_circle</md-icon><span>已经添加本站链接</span></li>
          <li><md-icon aria-hidden="true">check_circle</md-icon><span>不是纯采集或广告站点</span></li>
        </ul>
        <a
          class="apply-button"
          href="https://github.com/vahiru/blog/issues"
          target="_blank"
          rel="noopener noreferrer"
        >
          <md-icon aria-hidden="true">add</md-icon>
          <span>提交申请</span>
          <span class="visually-hidden">（新窗口打开）</span>
        </a>
      </aside>
    </div>
  </div>
</Layout>

<script>
  import "@material/web/ripple/ripple.js";

  document.querySelectorAll<HTMLImageElement>(".friend-avatar").forEach((image) => {
    image.addEventListener("error", () => {
      image.hidden = true;
    });
  });
</script>

<style>
  .friends-page {
    width: min(100%, 1180px);
    margin-inline: auto;
  }

  .page-intro {
    display: flex;
    max-width: 860px;
    align-items: flex-start;
    gap: 20px;
    padding: clamp(12px, 3vw, 32px) 0 clamp(36px, 6vw, 64px);
  }

  .intro-icon {
    display: grid;
    width: 64px;
    height: 64px;
    flex: 0 0 64px;
    place-items: center;
    border-radius: var(--md-sys-shape-corner-large-increased);
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
    rotate: -4deg;
  }

  .intro-icon md-icon {
    font-size: 32px;
  }

  .eyebrow {
    margin: 2px 0 6px;
    color: var(--md-sys-color-primary);
    font-size: var(--md-sys-typescale-label-medium-size);
    font-weight: 700;
    letter-spacing: 0.14em;
  }

  h1 {
    margin: 0;
    font-family: var(--md-ref-typeface-brand);
    font-size: clamp(38px, 6vw, var(--md-sys-typescale-display-medium-size));
    line-height: 1.12;
    font-weight: var(--md-sys-typescale-display-medium-weight);
  }

  .intro-copy {
    max-width: 680px;
    margin: 16px 0 0;
    color: var(--md-sys-color-on-surface-variant);
    font-size: var(--md-sys-typescale-body-large-size);
    line-height: 1.75;
  }

  .friends-layout {
    display: grid;
    gap: 24px;
    align-items: start;
  }

  .section-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }

  h2 {
    margin: 0;
    font-size: var(--md-sys-typescale-headline-small-size);
    line-height: var(--md-sys-typescale-headline-small-line-height);
    font-weight: 500;
  }

  .count-badge {
    padding: 6px 12px;
    border-radius: var(--md-sys-shape-corner-full);
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
    font-size: var(--md-sys-typescale-label-medium-size);
    font-weight: 600;
  }

  .friends-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 14px;
  }

  .friend-card {
    position: relative;
    display: flex;
    min-width: 0;
    min-height: 104px;
    align-items: center;
    gap: 16px;
    overflow: hidden;
    padding: 20px;
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: var(--md-sys-shape-corner-extra-large);
    background: var(--md-sys-color-surface-container-lowest);
    transition:
      translate var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-spatial),
      background-color var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects),
      box-shadow var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects);
  }

  .friend-card:hover {
    translate: 0 -3px;
    background: var(--md-sys-color-surface-container-low);
    box-shadow: var(--md-sys-elevation-level1);
  }

  .avatar-box {
    position: relative;
    display: grid;
    width: 64px;
    height: 64px;
    flex: 0 0 64px;
    overflow: hidden;
    place-items: center;
    border-radius: var(--md-sys-shape-corner-large-increased);
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
  }

  .friend-avatar {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .friend-avatar[hidden] {
    display: none;
  }

  .fallback-icon {
    opacity: 0.72;
  }

  .friend-info {
    min-width: 0;
    flex: 1;
  }

  .name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .friend-info h3 {
    min-width: 0;
    margin: 0;
    overflow: hidden;
    font-size: var(--md-sys-typescale-title-medium-size);
    line-height: var(--md-sys-typescale-title-medium-line-height);
    font-weight: 600;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .friend-info p {
    display: -webkit-box;
    margin: 5px 0 0;
    overflow: hidden;
    color: var(--md-sys-color-on-surface-variant);
    font-size: var(--md-sys-typescale-body-small-size);
    line-height: var(--md-sys-typescale-body-small-line-height);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .arrow-icon {
    color: var(--md-sys-color-primary);
    font-size: 20px;
    opacity: 0.7;
    transition: translate var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-spatial);
  }

  .friend-card:hover .arrow-icon {
    translate: 3px -3px;
  }

  .application-card {
    padding: 28px;
    border-radius: var(--md-sys-shape-corner-extra-large);
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
  }

  .application-icon {
    display: grid;
    width: 52px;
    height: 52px;
    place-items: center;
    margin-bottom: 20px;
    border-radius: var(--md-sys-shape-corner-large);
    background: color-mix(in srgb, var(--md-sys-color-on-secondary-container) 12%, transparent);
  }

  .application-card > p {
    margin: 12px 0 0;
    opacity: 0.82;
  }

  .application-card ul {
    display: grid;
    gap: 10px;
    margin: 22px 0 26px;
    padding: 0;
    list-style: none;
  }

  .application-card li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: var(--md-sys-typescale-body-medium-size);
  }

  .application-card li md-icon {
    font-size: 20px;
  }

  .apply-button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: var(--md-sys-shape-corner-full);
    background: var(--md-sys-color-secondary);
    color: var(--md-sys-color-on-secondary);
    font-size: var(--md-sys-typescale-label-large-size);
    font-weight: var(--md-sys-typescale-label-large-weight);
    box-shadow: var(--md-sys-elevation-level1);
    transition: box-shadow var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects);
  }

  .apply-button:hover {
    box-shadow: var(--md-sys-elevation-level2);
  }

  @media (min-width: 920px) {
    .friends-layout {
      grid-template-columns: minmax(0, 1fr) 320px;
    }

    .application-card {
      position: sticky;
      top: 24px;
    }
  }

  @media (max-width: 599px) {
    .page-intro {
      display: block;
      padding-top: 16px;
    }

    .intro-icon {
      width: 52px;
      height: 52px;
      margin-bottom: 20px;
    }

    .friend-card {
      min-height: 92px;
      padding: 16px;
      border-radius: var(--md-sys-shape-corner-large-increased);
    }

    .avatar-box {
      width: 56px;
      height: 56px;
      flex-basis: 56px;
      border-radius: var(--md-sys-shape-corner-large);
    }

    .application-card {
      margin-top: 8px;
    }

    .apply-button {
      width: 100%;
    }
  }
</style>
