---
import type { GetStaticPaths, Page } from "astro";
import { getCollection, type CollectionEntry } from "astro:content";
import TaxonomyView from "astro-mochi-tones:components/TaxonomyView.astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = (await getCollection("blog"))
    .filter((post) => !post.data.draft)
    .sort((left, right) => right.data.date.valueOf() - left.data.date.valueOf());
  const categories = new Set(posts.flatMap((post) => post.data.categories ?? []));

  return [...categories].flatMap((category) =>
    paginate(
      posts.filter((post) => post.data.categories?.includes(category)),
      { params: { category }, pageSize: 6 },
    ),
  );
};

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
const category = Astro.params.category ?? "";
---

<TaxonomyView page={page} kind="category" name={category} />
