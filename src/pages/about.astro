---
import Layout from "astro-mochi-tones:layouts/Layout.astro";
import "@material/web/icon/icon.js";

const profile = {
  name: "Vahiru",
  role: "数字创作者 · 开发者",
  avatar: "https://avatars.githubusercontent.com/u/84584330?v=4",
  bio: "愿你能被全世界温柔以待。",
  socials: [
    { name: "GitHub", icon: "code", url: "https://github.com/vahiru", external: true },
    { name: "Telegram", icon: "send", url: "https://t.me/vahiru", external: true },
    { name: "邮箱", icon: "mail", url: "mailto:nekovahiru@outlook.com", external: false },
  ],
};

const skills = ["Astro", "Python", "JavaScript", "MaiMaidx"];
---

<Layout title="关于我">
  <div class="about-page">
    <section class="profile-card" aria-labelledby="about-title">
      <div class="avatar-surface">
        <img
          src={profile.avatar}
          alt={`${profile.name} 的头像`}
          class="avatar"
          width="176"
          height="176"
          decoding="async"
          referrerpolicy="no-referrer"
        />
        <span class="status-dot" aria-label="在线探索中" title="在线探索中"></span>
      </div>

      <div class="profile-info">
        <p class="eyebrow">HELLO, I'M</p>
        <h1 id="about-title">{profile.name}</h1>
        <p class="role">{profile.role}</p>
        <p class="bio">{profile.bio}</p>

        <nav class="social-links" aria-label="联系方式">
          {
            profile.socials.map((social) => (
              <a
                href={social.url}
                target={social.external ? "_blank" : undefined}
                rel={social.external ? "noopener noreferrer" : undefined}
                class="social-link"
                aria-label={`${social.name}${social.external ? "（新窗口打开）" : ""}`}
              >
                <md-icon aria-hidden="true">{social.icon}</md-icon>
                <span>{social.name}</span>
              </a>
            ))
          }
        </nav>
      </div>
    </section>

    <div class="about-grid">
      <section class="info-card story-card" aria-labelledby="story-title">
        <div class="section-heading">
          <span class="section-icon" aria-hidden="true"><md-icon>auto_stories</md-icon></span>
          <div>
            <p class="section-label">MY STORY</p>
            <h2 id="story-title">关于我</h2>
          </div>
        </div>
        <p>
          高中生，现居辽宁，梦想变成一只猫娘。喜欢折腾一些有趣的东西，虽然偶尔会三分钟热度，也始终享受把想法做出来的过程。感谢你来到这里，祝你拥有美好的一天。
        </p>
      </section>

      <section class="info-card" aria-labelledby="skills-title">
        <div class="section-heading">
          <span class="section-icon secondary" aria-hidden="true"><md-icon>code_blocks</md-icon></span>
          <div>
            <p class="section-label">TOOLBOX</p>
            <h2 id="skills-title">技能树</h2>
          </div>
        </div>
        <ul class="skills-list" aria-label="掌握或正在学习的技术">
          {skills.map((skill) => <li>{skill}</li>)}
        </ul>
      </section>

      <section class="info-card contact-card" aria-labelledby="contact-title">
        <div class="section-heading">
          <span class="section-icon tertiary" aria-hidden="true"><md-icon>waving_hand</md-icon></span>
          <div>
            <p class="section-label">SAY HELLO</p>
            <h2 id="contact-title">联系我</h2>
          </div>
        </div>
        <p>
          欢迎通过 Telegram 或邮件联系我。也可以搜索用户名 <strong>vahiru</strong>，说不定会在网络的某个角落遇见我。
        </p>
      </section>
    </div>
  </div>
</Layout>

<style>
  .about-page {
    width: min(100%, 1040px);
    margin-inline: auto;
  }

  .profile-card {
    position: relative;
    display: grid;
    overflow: hidden;
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
    padding: clamp(28px, 6vw, 72px);
    border-radius: var(--md-sys-shape-corner-extra-extra-large);
    background:
      radial-gradient(circle at 100% 0, color-mix(in srgb, var(--md-sys-color-tertiary-container) 72%, transparent) 0, transparent 42%),
      var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
  }

  .profile-card::after {
    position: absolute;
    right: -64px;
    bottom: -96px;
    width: 240px;
    height: 240px;
    border: 1px solid color-mix(in srgb, currentColor 18%, transparent);
    border-radius: var(--md-sys-shape-corner-full);
    content: "";
  }

  .avatar-surface {
    position: relative;
    z-index: 1;
    width: clamp(144px, 22vw, 188px);
    aspect-ratio: 1;
    justify-self: center;
    padding: 8px;
    border-radius: var(--md-sys-shape-corner-extra-extra-large);
    background: color-mix(in srgb, var(--md-sys-color-surface) 82%, transparent);
    box-shadow: var(--md-sys-elevation-level2);
    rotate: -3deg;
  }

  .avatar {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: calc(var(--md-sys-shape-corner-extra-extra-large) - 8px);
    object-fit: cover;
  }

  .status-dot {
    position: absolute;
    right: 2px;
    bottom: 18px;
    width: 24px;
    height: 24px;
    border: 5px solid var(--md-sys-color-surface);
    border-radius: var(--md-sys-shape-corner-full);
    background: #34a853;
  }

  .profile-info {
    position: relative;
    z-index: 1;
    min-width: 0;
    text-align: center;
  }

  .eyebrow,
  .section-label {
    margin: 0;
    font-size: var(--md-sys-typescale-label-medium-size);
    font-weight: 700;
    letter-spacing: 0.16em;
  }

  .eyebrow {
    opacity: 0.7;
  }

  h1 {
    margin: 6px 0 0;
    font-family: var(--md-ref-typeface-brand);
    font-size: clamp(42px, 7vw, var(--md-sys-typescale-display-large-size));
    line-height: 1.08;
    letter-spacing: var(--md-sys-typescale-display-large-tracking);
  }

  .role {
    margin: 10px 0 0;
    font-size: var(--md-sys-typescale-title-large-size);
    line-height: var(--md-sys-typescale-title-large-line-height);
  }

  .bio {
    margin: 18px 0 0;
    font-size: var(--md-sys-typescale-body-large-size);
    opacity: 0.82;
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    margin-top: 28px;
  }

  .social-link {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: var(--md-sys-shape-corner-full);
    background: color-mix(in srgb, var(--md-sys-color-surface) 78%, transparent);
    color: var(--md-sys-color-on-surface);
    font-size: var(--md-sys-typescale-label-large-size);
    font-weight: var(--md-sys-typescale-label-large-weight);
    transition:
      translate var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-spatial),
      background-color var(--md-sys-motion-duration-fast) var(--md-sys-motion-easing-effects);
  }

  .social-link:hover {
    translate: 0 -2px;
    background: var(--md-sys-color-surface);
  }

  .social-link md-icon {
    font-size: 20px;
  }

  .about-grid {
    display: grid;
    gap: 16px;
    margin-top: 24px;
  }

  .info-card {
    padding: clamp(24px, 4vw, 36px);
    border-radius: var(--md-sys-shape-corner-extra-large);
    background: var(--md-sys-color-surface-container-low);
  }

  .story-card {
    background: var(--md-sys-color-surface-container-lowest);
    box-shadow: var(--md-sys-elevation-level1);
  }

  .contact-card {
    background: var(--md-sys-color-tertiary-container);
    color: var(--md-sys-color-on-tertiary-container);
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .section-icon {
    display: grid;
    width: 48px;
    height: 48px;
    flex: 0 0 48px;
    place-items: center;
    border-radius: var(--md-sys-shape-corner-large);
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
  }

  .section-icon.secondary {
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
  }

  .section-icon.tertiary {
    background: color-mix(in srgb, var(--md-sys-color-on-tertiary-container) 12%, transparent);
    color: currentColor;
  }

  .section-label {
    color: var(--md-sys-color-on-surface-variant);
  }

  .contact-card .section-label {
    color: currentColor;
    opacity: 0.68;
  }

  h2 {
    margin: 2px 0 0;
    font-size: var(--md-sys-typescale-headline-small-size);
    line-height: var(--md-sys-typescale-headline-small-line-height);
    font-weight: 500;
  }

  .info-card > p {
    margin: 24px 0 0;
    color: var(--md-sys-color-on-surface-variant);
    line-height: 1.8;
  }

  .contact-card > p {
    color: currentColor;
    opacity: 0.86;
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .skills-list li {
    padding: 8px 16px;
    border: 1px solid var(--md-sys-color-outline-variant);
    border-radius: var(--md-sys-shape-corner-full);
    color: var(--md-sys-color-on-surface-variant);
    font-size: var(--md-sys-typescale-label-large-size);
    font-weight: 600;
  }

  @media (min-width: 720px) {
    .profile-card {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .profile-info {
      text-align: left;
    }

    .social-links {
      justify-content: flex-start;
    }

    .about-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .story-card {
      grid-row: span 2;
    }
  }

  @media (max-width: 599px) {
    .profile-card {
      padding-inline: 20px;
      border-radius: var(--md-sys-shape-corner-extra-large);
    }

    .social-link {
      flex: 1 1 120px;
      justify-content: center;
    }
  }
</style>
