---
// ==================================================
// 🔴 服务端代码区域 (Frontmatter)
// ==================================================

import { getCollection } from "astro:content";
import Layout from "astro-mochi-tones:layouts/Layout.astro";
import PostCard from "astro-mochi-tones:components/PostCard.astro";

// 1. 获取文章
const allPosts = await getCollection("blog");

// 2. 处理排序
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
    const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
    return dateB - dateA;
  });

// 3. 逻辑分拆：最新一篇作为 Featured
const featuredPost = posts[0];
const regularPosts = posts.slice(1, 9);

// 4. 提取分类
const categories = [...new Set(posts.flatMap(post => post.data.categories || []))].slice(0, 12);

// 5. 计算全站统计
const stats = {
  posts: posts.length,
  categories: new Set(posts.flatMap(post => post.data.categories || [])).size,
  tags: new Set(posts.flatMap(post => post.data.tags || [])).size,
};
---

<Layout
  title="Home"
  description="这里是一只猫猫的自留地"
  image="/images/cover.jpg"
>
  <div class="md3-layout-grid">
    <div class="content-wrapper">
      <!-- 头部：Hero Section -->
      <header class="page-header">
        <h1 class="display-medium hero-title">欢迎到访 Vahiru's blog</h1>
        <p class="body-large secondary-text">记录技术、生活与胡思乱想。</p>
        
        <div class="header-actions">
          <md-filled-button href="/about">
            About Me
            <md-icon slot="icon">arrow_forward</md-icon>
          </md-filled-button>
          <md-text-button href="/archives/1">
            Explore Archives
          </md-text-button>
        </div>
      </header>

      <!-- 文章流 (主体部分) -->
      <main class="post-feed">
        {featuredPost && (
            <section class="featured-section">
                <PostCard post={featuredPost} featured={true} />
            </section>
        )}

        <section class="recent-posts">
            <h2 class="title-medium section-label">最近更新</h2>
            <div class="vertical-posts">
              {regularPosts.map((post) => <PostCard post={post} />)}
              
              {posts.length === 0 && (
                <div class="empty-state">
                  还没有文章，请在 src/content/blog/ 下创建 .md 文件
                </div>
              )}
            </div>
        </section>

        {posts.length > 8 && (
          <div class="pagination-footer">
            <md-filled-tonal-button href="/archives/1">
              View All Posts
              <md-icon slot="icon">arrow_forward</md-icon>
            </md-filled-tonal-button>
          </div>
        )}
      </main>

      <!-- 侧边栏 (辅助部分) -->
      <aside class="sidebar">
        <section class="sidebar-section stats-widget">
          <h3 class="label-large section-title">全站统计</h3>
          <div class="stats-grid">
            <div class="stat-item">
              <span class="title-medium stat-value">{stats.posts}</span>
              <span class="label-small stat-label">文章</span>
            </div>
            <div class="stat-item">
              <span class="title-medium stat-value">{stats.categories}</span>
              <span class="label-small stat-label">分类</span>
            </div>
            <div class="stat-item">
              <span class="title-medium stat-value">{stats.tags}</span>
              <span class="label-small stat-label">标签</span>
            </div>
          </div>
        </section>

        {categories.length > 0 && (
          <section class="sidebar-section">
            <h3 class="label-large section-title">快速导航</h3>
            <md-chip-set>
              {categories.map(cat => (
                <md-assist-chip label={cat} href={`/categories/${cat}/1`}>
                  <md-icon slot="icon">category</md-icon>
                </md-assist-chip>
              ))}
            </md-chip-set>
          </section>
        )}
      </aside>
    </div>
  </div>
</Layout>

<script>
  // 注册 MD3 组件
  import "@material/web/button/filled-button.js";
  import "@material/web/button/text-button.js";
  import "@material/web/button/filled-tonal-button.js";
  import "@material/web/iconbutton/icon-button.js";
  import "@material/web/chips/chip-set.js";
  import "@material/web/chips/assist-chip.js";
</script>

<style>
  /* === M3 Adaptive Layout Grid === */
  .md3-layout-grid {
    display: flex;
    flex-direction: column;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    padding: 0 var(--md-sys-layout-margin);
  }

  /* Content Wrapper: 12-column logic */
  .content-wrapper {
    display: grid;
    gap: var(--md-sys-layout-gutter);
    width: 100%;
    box-sizing: border-box;
  }

  /* Page Header (Hero) */
  .page-header {
    padding: 6rem 0 4rem 0;
  }

  .hero-title {
    margin-bottom: 0.75rem;
    color: var(--md-sys-color-on-surface);
    font-weight: 400;
  }

  .secondary-text {
    color: var(--md-sys-color-on-surface-variant);
    margin-bottom: 2rem;
    max-width: 600px;
    opacity: 0.8;
  }

  .header-actions {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  /* Grid Layouts by Device Size */
  
  /* Desktop (Expanded: >= 840px) - 12 Columns */
  @media (min-width: 840px) {
    .content-wrapper {
      grid-template-columns: repeat(12, 1fr);
      row-gap: 4rem;
    }
    .page-header {
      grid-column: span 12;
    }
    .post-feed {
      grid-column: span 9;
    }
    .sidebar {
      grid-column: span 3;
      position: sticky;
      top: 2rem;
      height: fit-content;
    }
  }

  /* Tablet (Medium: 600-839px) - 8 Columns */
  @media (min-width: 600px) and (max-width: 839px) {
    .content-wrapper {
      grid-template-columns: repeat(8, 1fr);
      row-gap: 3rem;
    }
    .page-header, .sidebar, .post-feed {
      grid-column: span 8;
    }
  }

  /* Mobile (Compact: < 600px) - 4 Columns */
  @media (max-width: 599px) {
    .content-wrapper {
      display: flex;
      flex-direction: column;
      gap: 32px;
    }
    .hero-title {
      font-size: var(--md-sys-typescale-display-small-size);
      line-height: var(--md-sys-typescale-display-small-line-height);
    }
    .page-header {
        padding: 3rem 0;
    }
  }

  /* Sections */
  .section-label {
    margin-bottom: 1.5rem;
    color: var(--md-sys-color-on-surface-variant);
    font-weight: 500;
    display: block;
    opacity: 0.7;
  }

  .featured-section {
      grid-column: span 12;
      margin-bottom: 1rem;
  }

  .vertical-posts {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Sidebar Styling */
  .sidebar-section {
    background-color: var(--md-sys-color-surface-container);
    padding: 1.5rem;
    border-radius: 28px; /* M3 Extra Large */
    margin-bottom: 24px;
  }

  .section-title {
    margin-bottom: 1.25rem;
    color: var(--md-sys-color-on-surface-variant);
    font-weight: 500;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: var(--md-sys-color-surface-container-low);
    padding: 12px 4px;
    border-radius: 16px;
  }

  .stat-value {
    color: var(--md-sys-color-primary);
  }

  .stat-label {
    color: var(--md-sys-color-on-surface-variant);
  }

  .pagination-footer {
    margin-top: 4rem;
    text-align: center;
  }

  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background-color: var(--md-sys-color-surface-container-low);
    border-radius: 28px;
    color: var(--md-sys-color-on-surface-variant);
    border: 1px dashed var(--md-sys-color-outline-variant);
  }
</style>
