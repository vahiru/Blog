---
// ==================================================
// 🔴 服务端代码区域 (Frontmatter)
// ==================================================

import { getCollection } from "astro:content";
import Layout from "astro-mochi-tones:layouts/Layout.astro";
import PostCard from "astro-mochi-tones:components/PostCard.astro";

// 1. 获取文章
const allPosts = await getCollection("blog");

// 2. 处理排序
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
    const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
    return dateB - dateA;
  });

// 3. 提取分类
const categories = [...new Set(posts.flatMap(post => post.data.categories || []))].slice(0, 12);

// 4. 计算全站统计
const stats = {
  posts: posts.length,
  categories: new Set(posts.flatMap(post => post.data.categories || [])).size,
  tags: new Set(posts.flatMap(post => post.data.tags || [])).size,
};
---

<Layout
  title="Home"
  description="这里是一只猫猫的自留地"
  image="/images/cover.jpg"
>
  <div class="md3-layout-grid">
    <div class="content-wrapper">
      <!-- 头部：核心信息 -->
      <header class="page-header">
        <h1 class="display-large">欢迎到访 Vahiru's blog</h1>
        <p class="body-large secondary-text">这里是一只猫猫的自留地，记录技术、生活与胡思乱想。</p>
        
        <div class="header-actions">
          <md-filled-button href="/about">
            About Me
            <md-icon slot="icon">arrow_forward</md-icon>
          </md-filled-button>
          <md-text-button href="/archives/1">
            Explore Archives
          </md-text-button>
        </div>
      </header>

      <!-- 侧边栏：移动端会排到头部下方，文章上方 -->
      <aside class="sidebar">
        <section class="sidebar-section stats-widget">
          <h3 class="label-large">全站统计</h3>
          <div class="stats-grid">
            <div class="stat-item">
              <span class="stat-value display-small">{stats.posts}</span>
              <span class="stat-label label-medium">文章</span>
            </div>
            <div class="stat-item">
              <span class="stat-value display-small">{stats.categories}</span>
              <span class="stat-label label-medium">分类</span>
            </div>
            <div class="stat-item">
              <span class="stat-value display-small">{stats.tags}</span>
              <span class="stat-label label-medium">标签</span>
            </div>
          </div>
        </section>

        {categories.length > 0 && (
          <section class="sidebar-section">
            <h3 class="label-large">导航</h3>
            <md-chip-set>
              {categories.map(cat => (
                <md-assist-chip label={cat} href={`/categories/${cat}/1`}>
                  <md-icon slot="icon">category</md-icon>
                </md-assist-chip>
              ))}
            </md-chip-set>
          </section>
        )}
      </aside>

      <!-- 文章流 -->
      <main class="post-feed">
        <h2 class="title-large section-label">Recent Posts</h2>
        <div class="vertical-posts">
          {posts.slice(0, 8).map((post) => <PostCard post={post} />)}
          
          {posts.length === 0 && (
            <div class="empty-state">
              还没有文章，请在 src/content/blog/ 下创建 .md 文件
            </div>
          )}
        </div>

        {posts.length > 8 && (
          <div class="pagination-footer">
            <md-filled-tonal-button href="/archives/1">
              View All Posts
              <md-icon slot="icon">arrow_forward</md-icon>
            </md-filled-tonal-button>
          </div>
        )}
      </main>
    </div>
  </div>
</Layout>

<script>
  // 注册 MD3 组件
  import "@material/web/button/filled-button.js";
  import "@material/web/button/text-button.js";
  import "@material/web/button/filled-tonal-button.js";
  import "@material/web/iconbutton/icon-button.js";
  import "@material/web/chips/chip-set.js";
  import "@material/web/chips/assist-chip.js";
</script>

<style>
  /* === MD3 响应式布局网格实现 === */
  .md3-layout-grid {
    display: flex;
    flex-direction: column;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  /* 页面头部 */
  .page-header {
    padding: 4rem 1rem 3rem 1rem;
    max-width: 800px; /* 限制阅读宽度 */
  }

  .page-header h1 {
    margin-bottom: 1rem;
    color: var(--md-sys-color-on-surface);
  }

  .secondary-text {
    color: var(--md-sys-color-on-surface-variant);
    margin-bottom: 2rem;
  }

  .header-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  /* 内容包装器：桌面端 12 列网格逻辑 */
  .content-wrapper {
    display: grid;
    gap: 24px;
    width: 100%;
    box-sizing: border-box;
  }

  /* 桌面端 (Expanded: >= 840px) */
  @media (min-width: 840px) {
    .content-wrapper {
      grid-template-columns: repeat(12, 1fr);
      padding: 2rem 1rem 0 1rem;
    }
    .page-header {
      grid-column: span 8;
      grid-row: 1;
    }
    .post-feed {
      grid-column: span 8;
      grid-row: 2;
    }
    .sidebar {
      grid-column: span 4;
      grid-row: 1 / 3;
      position: sticky;
      top: 2rem;
      height: fit-content;
    }
    .desktop-only {
      display: block;
    }
  }

  /* 平板端 (Medium: 600-839px) */
  @media (min-width: 600px) and (max-width: 839px) {
    .content-wrapper {
      grid-template-columns: repeat(8, 1fr);
      padding: 0 1.5rem;
    }
    .page-header, .sidebar, .post-feed {
      grid-column: span 8;
    }
    .desktop-only {
      display: none;
    }
  }

  /* 移动端 (Compact: < 600px) */
  @media (max-width: 599px) {
    .content-wrapper {
      display: block; /* 移动端改用块级布局，简化对齐 */
      padding: 0;
    }
    .page-header, .sidebar, .post-feed {
      width: 100%;
      margin: 0 auto;
    }
    .page-header {
      padding: 1rem 0;
    }
    .page-header h1 {
      font-size: 2.25rem; /* 进一步缩小标题以适应窄屏 */
      line-height: 1.2;
    }
    .sidebar-section {
      padding: 1rem 0;
      background: transparent;
      border-bottom: 1px solid var(--md-sys-color-outline-variant);
      border-radius: 0;
      margin-bottom: 0;
    }
    .desktop-only {
      display: none;
    }
    .vertical-posts {
      gap: 20px;
      padding: 1.5rem 0;
    }
  }

  /* 文章流样式 */
  .section-label {
    margin-bottom: 1.5rem;
    color: var(--md-sys-color-on-surface);
    opacity: 0.8;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .vertical-posts {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    background-color: var(--md-sys-color-surface-container-low);
    border-radius: 16px;
    color: var(--md-sys-color-on-surface-variant);
    border: 1px dashed var(--md-sys-color-outline-variant);
  }

  .pagination-footer {
    margin-top: 3rem;
    text-align: center;
  }

  /* 侧边栏样式 */
  .sidebar-section {
    background-color: var(--md-sys-color-surface-container);
    padding: 1.5rem;
    border-radius: 24px;
    margin-bottom: 24px;
    box-shadow: var(--md-sys-elevation-level1);
  }

  .sidebar-section h3 {
    margin-bottom: 1rem;
    color: var(--md-sys-color-primary);
    font-weight: 600;
  }

  .social-icons {
    display: flex;
    gap: 8px;
  }

  /* 统计小部件样式 */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-value {
    color: var(--md-sys-color-primary);
    font-weight: 500;
  }

  .stat-label {
    color: var(--md-sys-color-on-surface-variant);
    opacity: 0.8;
  }
</style>
