---
import { getCollection } from "astro:content";
import Layout from "astro-mochi-tones:layouts/Layout.astro";
import PostCard from "astro-mochi-tones:components/PostCard.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPost = posts.find((post) => post.data.pinned) ?? posts[0];
const regularPosts = posts.filter((post) => post.id !== featuredPost?.id).slice(0, 8);
const categories = [...new Set(posts.flatMap((post) => post.data.categories ?? []))].slice(0, 10);
const stats = {
  posts: posts.length,
  categories: new Set(posts.flatMap((post) => post.data.categories ?? [])).size,
  tags: new Set(posts.flatMap((post) => post.data.tags ?? [])).size,
};
---

<Layout
  title="首页"
  description="Vahiru 的个人博客，记录技术、生活与偶尔冒出的奇思妙想。"
  image="/images/cover.jpg"
>
  <div class="home-shell">
    <header class="hero">
      <div class="hero-copy">
        <span class="hero-kicker label-large">
          <md-icon aria-hidden="true">auto_awesome</md-icon>
          MOCHI NOTES · 随心更新
        </span>
        <h1 class="hero-title">在代码与日常之间，收藏一点灵感。</h1>
        <p class="hero-description body-large">
          欢迎来到 Vahiru 的自留地。这里有技术实践、生活切片，也有那些值得被认真记住的小事。
        </p>

        <div class="hero-actions">
          <md-filled-button href="/archives">
            开始阅读
            <md-icon slot="icon">arrow_forward</md-icon>
          </md-filled-button>
          <md-text-button href="/about">认识我</md-text-button>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="visual-card visual-card-main">
          <md-icon>terminal</md-icon>
          <span>build · learn · share</span>
        </div>
        <div class="visual-card visual-card-palette"><md-icon>palette</md-icon></div>
        <div class="visual-card visual-card-cat"><md-icon>pets</md-icon></div>
        <span class="visual-ring"></span>
      </div>
    </header>

    <div class="home-grid">
      <section class="post-feed" aria-labelledby="recent-posts-title">
        {featuredPost && (
          <section class="featured-section" aria-label="精选文章">
            <PostCard post={featuredPost} featured />
          </section>
        )}

        <section class="recent-posts">
          <div class="section-heading">
            <div>
              <span class="section-eyebrow label-medium">LATEST STORIES</span>
              <h2 id="recent-posts-title" class="headline-small">最近更新</h2>
            </div>
            <a class="section-link label-large" href="/archives">
              查看全部
              <md-icon aria-hidden="true">arrow_forward</md-icon>
            </a>
          </div>

          <div class="post-grid">
            {regularPosts.map((post) => <PostCard post={post} />)}
          </div>

          {posts.length === 0 && (
            <div class="empty-state">
              <md-icon aria-hidden="true">edit_note</md-icon>
              <h2 class="title-large">还没有文章</h2>
              <p class="body-medium">在 src/content/blog 下创建第一篇 Markdown 文章吧。</p>
            </div>
          )}
        </section>
      </section>

      <aside class="sidebar" aria-label="博客概览">
        <section class="sidebar-card stats-card">
          <div class="sidebar-heading">
            <span class="sidebar-icon"><md-icon aria-hidden="true">monitoring</md-icon></span>
            <div>
              <span class="label-medium sidebar-eyebrow">SITE SNAPSHOT</span>
              <h2 class="title-medium">全站统计</h2>
            </div>
          </div>
          <div class="stats-grid">
            <div class="stat-item">
              <strong>{stats.posts}</strong>
              <span>文章</span>
            </div>
            <div class="stat-item">
              <strong>{stats.categories}</strong>
              <span>分类</span>
            </div>
            <div class="stat-item">
              <strong>{stats.tags}</strong>
              <span>标签</span>
            </div>
          </div>
        </section>

        {categories.length > 0 && (
          <section class="sidebar-card category-card">
            <div class="sidebar-heading">
              <span class="sidebar-icon tertiary"><md-icon aria-hidden="true">category</md-icon></span>
              <div>
                <span class="label-medium sidebar-eyebrow">DISCOVER</span>
                <h2 class="title-medium">按主题漫游</h2>
              </div>
            </div>
            <md-chip-set aria-label="文章分类">
              {categories.map((category) => (
                <md-assist-chip label={category} href={`/categories/${encodeURIComponent(category)}`}>
                  <md-icon slot="icon">tag</md-icon>
                </md-assist-chip>
              ))}
            </md-chip-set>
          </section>
        )}

        <section class="sidebar-card note-card">
          <md-icon aria-hidden="true">favorite</md-icon>
          <p class="body-medium">“愿你能被这个世界温柔以待，也愿每次到访都能带走一点好心情。”</p>
        </section>
      </aside>
    </div>
  </div>
</Layout>

<script>
  import "@material/web/button/filled-button.js";
  import "@material/web/button/text-button.js";
  import "@material/web/chips/assist-chip.js";
  import "@material/web/chips/chip-set.js";
</script>

<style>
  .home-shell {
    width: min(100%, 1280px);
    margin: 0 auto;
  }

  .hero {
    position: relative;
    display: grid;
    min-height: 360px;
    grid-template-columns: minmax(0, 7fr) minmax(300px, 5fr);
    align-items: center;
    gap: clamp(28px, 5vw, 72px);
    overflow: hidden;
    padding: clamp(32px, 5vw, 64px);
    border-radius: var(--md-sys-shape-corner-extra-extra-large) var(--md-sys-shape-corner-extra-extra-large) var(--md-sys-shape-corner-large-increased) var(--md-sys-shape-corner-extra-extra-large);
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
  }

  .hero::before {
    position: absolute;
    inset: auto -10% -55% 38%;
    width: 60%;
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--md-sys-color-on-primary-container) 22%, transparent);
    border-radius: 50%;
    content: "";
  }

  .hero-copy {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .hero-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 12px;
    border-radius: var(--md-sys-shape-corner-full);
    background: color-mix(in srgb, var(--md-sys-color-surface-container-lowest) 72%, transparent);
    color: var(--md-sys-color-on-primary-container);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .hero-kicker md-icon {
    width: 18px;
    height: 18px;
    flex-basis: 18px;
    font-size: 18px;
  }

  .hero-title {
    max-width: 760px;
    margin: 22px 0 16px;
    font-family: var(--md-ref-typeface-brand);
    font-size: clamp(40px, 5.2vw, 64px);
    font-weight: 500;
    letter-spacing: -0.035em;
    line-height: 1.08;
  }

  .hero-description {
    max-width: 640px;
    margin: 0;
    color: var(--md-sys-color-on-primary-container);
    opacity: 0.82;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-top: 28px;
  }

  .hero-actions md-text-button {
    --md-text-button-label-text-color: var(--md-sys-color-on-primary-container);
  }

  .hero-visual {
    position: relative;
    min-height: 250px;
  }

  .visual-card {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--md-sys-elevation-level1);
  }

  .visual-card-main {
    inset: 24px 22px 28px 0;
    flex-direction: column;
    gap: 14px;
    border-radius: var(--md-sys-shape-corner-extra-large-increased) var(--md-sys-shape-corner-extra-extra-large) var(--md-sys-shape-corner-extra-large-increased) var(--md-sys-shape-corner-medium);
    background: var(--md-sys-color-surface-container-lowest);
    color: var(--md-sys-color-primary);
    rotate: -3deg;
  }

  .visual-card-main md-icon {
    width: 64px;
    height: 64px;
    font-size: 64px;
    font-variation-settings: "FILL" 0, "wght" 300, "GRAD" 0, "opsz" 48;
  }

  .visual-card-main span {
    color: var(--md-sys-color-on-surface-variant);
    font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
    font-size: 13px;
  }

  .visual-card-palette,
  .visual-card-cat {
    width: 72px;
    height: 72px;
    border-radius: var(--md-sys-shape-corner-extra-large);
  }

  .visual-card-palette {
    inset: 0 0 auto auto;
    background: var(--md-sys-color-tertiary-container);
    color: var(--md-sys-color-on-tertiary-container);
    rotate: 8deg;
  }

  .visual-card-cat {
    inset: auto auto 0 8%;
    background: var(--md-sys-color-secondary-container);
    color: var(--md-sys-color-on-secondary-container);
    rotate: -9deg;
  }

  .visual-ring {
    position: absolute;
    inset: 45% -8% auto auto;
    width: 54px;
    height: 54px;
    border: 10px solid var(--md-sys-color-primary);
    border-radius: 50%;
    opacity: 0.42;
  }

  .home-grid {
    display: grid;
    gap: 32px;
    margin-top: 40px;
  }

  .post-feed,
  .sidebar {
    min-width: 0;
  }

  .featured-section {
    margin-bottom: 48px;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 20px;
  }

  .section-eyebrow,
  .sidebar-eyebrow {
    display: block;
    margin-bottom: 4px;
    color: var(--md-sys-color-primary);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .section-heading h2,
  .sidebar-heading h2 {
    margin: 0;
  }

  .section-link {
    display: inline-flex;
    min-height: 40px;
    flex: 0 0 auto;
    align-items: center;
    gap: 6px;
    padding: 0 14px;
    border-radius: var(--md-sys-shape-corner-full);
    color: var(--md-sys-color-primary);
    font-weight: 700;
  }

  .section-link:hover {
    background: color-mix(in srgb, var(--md-sys-color-primary) 8%, transparent);
  }

  .section-link md-icon {
    width: 18px;
    height: 18px;
    flex-basis: 18px;
    font-size: 18px;
  }

  .post-grid {
    display: grid;
    gap: 20px;
  }

  .sidebar {
    display: grid;
    align-content: start;
    gap: 20px;
  }

  .sidebar-card {
    padding: 24px;
    border-radius: var(--md-sys-shape-corner-extra-large);
    background: var(--md-sys-color-surface-container);
  }

  .sidebar-heading {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 20px;
  }

  .sidebar-icon {
    display: grid;
    width: 48px;
    height: 48px;
    flex: 0 0 48px;
    place-items: center;
    border-radius: var(--md-sys-shape-corner-large);
    background: var(--md-sys-color-primary-container);
    color: var(--md-sys-color-on-primary-container);
  }

  .sidebar-icon.tertiary {
    background: var(--md-sys-color-tertiary-container);
    color: var(--md-sys-color-on-tertiary-container);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .stat-item {
    display: flex;
    min-width: 0;
    min-height: 84px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: var(--md-sys-shape-corner-large);
    background: var(--md-sys-color-surface-container-highest);
    color: var(--md-sys-color-on-surface);
  }

  .stat-item strong {
    color: var(--md-sys-color-primary);
    font-size: var(--md-sys-typescale-title-large-size);
  }

  .stat-item span {
    margin-top: 2px;
    color: var(--md-sys-color-on-surface-variant);
    font-size: var(--md-sys-typescale-label-small-size);
  }

  .category-card md-chip-set {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .note-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: var(--md-sys-color-tertiary-container);
    color: var(--md-sys-color-on-tertiary-container);
  }

  .note-card p {
    margin: 0;
  }

  .empty-state {
    display: grid;
    min-height: 260px;
    place-content: center;
    justify-items: center;
    padding: 32px;
    border: 1px dashed var(--md-sys-color-outline);
    border-radius: var(--md-sys-shape-corner-extra-large);
    color: var(--md-sys-color-on-surface-variant);
    text-align: center;
  }

  .empty-state md-icon {
    width: 48px;
    height: 48px;
    font-size: 48px;
  }

  .empty-state h2 {
    margin: 12px 0 4px;
  }

  .empty-state p {
    margin: 0;
  }

  @media (min-width: 700px) {
    .post-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1100px) {
    .home-grid {
      grid-template-columns: minmax(0, 8fr) minmax(280px, 4fr);
      align-items: start;
    }

    .sidebar {
      position: sticky;
      top: 24px;
    }
  }

  @media (min-width: 600px) and (max-width: 1099px) {
    .sidebar {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .note-card {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 839px) {
    .hero {
      min-height: 0;
      grid-template-columns: 1fr;
      padding: 32px;
    }

    .hero-visual {
      display: none;
    }
  }

  @media (max-width: 599px) {
    .hero {
      padding: 28px 24px 32px;
      border-radius: var(--md-sys-shape-corner-extra-large-increased) var(--md-sys-shape-corner-extra-large-increased) var(--md-sys-shape-corner-large) var(--md-sys-shape-corner-extra-large-increased);
    }

    .hero-title {
      margin-top: 18px;
      font-size: clamp(36px, 12vw, 48px);
    }

    .home-grid {
      margin-top: 32px;
    }

    .featured-section {
      margin-bottom: 40px;
    }

    .section-heading {
      align-items: center;
    }

    .sidebar-card {
      padding: 20px;
    }
  }
</style>
